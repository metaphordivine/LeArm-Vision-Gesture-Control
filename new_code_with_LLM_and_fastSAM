def ask_ai_what_is_this(cv2_img, prompt_obj_name):
    """
    裁剪出的物体图片 -> 发送给阿里云 Qwen-VL -> 判断是否是目标物体
    """
    import os
    if not os.path.exists('ai_debug'): os.makedirs('ai_debug')
    filename = f"ai_debug/{int(time.time())}.jpg"
    cv2.imwrite(filename, cv2_img)
    print(f"📸 已将发送给AI的切片保存至: {filename}")

    try:
        # 1. 图像转 Base64
        _, buffer = cv2.imencode('.jpg', cv2_img)
        img_b64 = base64.b64encode(buffer).decode('utf-8')
        img_data = f"data:image/jpeg;base64,{img_b64}"

        # 2. 构建 Prompt：让 AI 判断物体是否符合描述
        prompt = f"""
        用户的指令是：“{prompt_obj_name}”。
        请判断这张图片中的物体，是否是用户指令中想要获取的目标？
        请只回答"是"或"否"。
        例如，如果用户说"抓取红色的苹果"，而图片中确实是一个红色的苹果，你应该回答"是"。如果图片中是一个绿色的苹果，或者是一个红色的球，你都应该回答"否"。
        """

        # 3. 调用 Qwen-VL-Plus
        response = dashscope.MultiModalConversation.call(
            model='qwen3-vl-plus',  # 使用阿里最强的视觉模型
            messages=[{
                'role': 'user',
                'content': [
                    {'image': img_data},
                    {'text': prompt}
                ]
            }],
            api_key=DASHSCOPE_API_KEY
        )

        if response.status_code == HTTPStatus.OK:
            answer = response.output.choices[0].message.content[0]['text']
            print(f"🤖 AI 分析结果: {answer}")
            return "是" in answer
        else:
            print(f"API Error: {response.message}")
            return False
    except Exception as e:
        print(f"AI 请求失败: {e}")
        return False

# ================= 🦴 骨架化抓取点检测函数（修改版）=================
def get_skeleton_grasp_pose_advanced(mask_uint8, max_width=GRIPPER_MAX_WIDTH_PIXELS, sample_step=SKELETON_SAMPLE_STEP):
    """
    高级骨架化抓取点检测算法（简化版，不返回角度）
    参数:
        mask_uint8: 二值掩码图像 (0-255)
        max_width: 机械爪最大开合度（像素）
        sample_step: 骨架采样步长
    返回:
        (grasp_x, grasp_y), skeleton_img, local_width 或 None（失败时）
    """
    try:
        from skimage.morphology import skeletonize
        
        # 1. 二值化掩码
        binary = mask_uint8 > 0
        
        # 2. 提取骨架
        skeleton = skeletonize(binary)
        
        # 将骨架转换为uint8图像用于显示
        skeleton_img = (skeleton * 255).astype(np.uint8)
        
        # 3. 获取骨架点坐标
        skel_coords = np.argwhere(skeleton)  # 返回 [[y, x], ...]
        
        if len(skel_coords) < 3:
            # 骨架点太少，使用简单策略
            return get_skeleton_grasp_pose_simple(mask_uint8)
        
        # 4. 计算掩码质心
        moments = cv2.moments(mask_uint8)
        if moments['m00'] == 0:
            centroid = np.array([mask_uint8.shape[1]//2, mask_uint8.shape[0]//2])
        else:
            centroid = np.array([moments['m10']/moments['m00'], moments['m01']/moments['m00']])
        
        # 5. 对骨架点进行采样
        sampled_points = []
        for i in range(0, len(skel_coords), sample_step):
            y, x = skel_coords[i]
            sampled_points.append((x, y, i))  # (x, y, 原始索引)
        
        # 6. 检测每个采样点的局部宽度
        valid_points = []
        for x, y, idx in sampled_points:
            # 计算切线方向（使用相邻点）
            prev_idx = max(0, idx - 5)
            next_idx = min(len(skel_coords) - 1, idx + 5)
            
            if prev_idx == next_idx:
                continue
                
            # 获取前后点计算切线
            p1 = skel_coords[prev_idx]  # [y, x]
            p2 = skel_coords[next_idx]  # [y, x]
            
            # 计算切线角度（用于宽度测量）
            dx = p2[1] - p1[1]
            dy = p2[0] - p1[0]
            
            if dx == 0 and dy == 0:
                continue
                
            tangent_angle = math.atan2(dy, dx)
            normal_angle = tangent_angle + math.pi/2  # 法线方向
            
            # 沿法线方向检测宽度
            local_width = measure_width_along_normal(mask_uint8, x, y, normal_angle)
            
            if local_width > 0 and local_width <= max_width:
                # 计算到质心的距离
                dist_to_centroid = math.hypot(x - centroid[0], y - centroid[1])
                valid_points.append({
                    'point': (x, y),
                    'width': local_width,
                    'dist_to_centroid': dist_to_centroid,
                })
        
        # 7. 选择最优抓取点
        if not valid_points:
            # 没有符合条件的点，使用简单策略
            return get_skeleton_grasp_pose_simple(mask_uint8)
        
        # 策略：优先选择距离质心近的点
        valid_points.sort(key=lambda p: p['dist_to_centroid'])
        best = valid_points[0]
        
        return best['point'], skeleton_img, best['width']
        
    except Exception as e:
        # 只在真正出错时打印，避免刷屏
        return None

def get_skeleton_grasp_pose_simple(mask_uint8):
    """
    简单骨架化策略（返回骨架图像）
    """
    try:
        from skimage.morphology import skeletonize
        
        binary = mask_uint8 > 0
        skeleton = skeletonize(binary)
        skeleton_img = (skeleton * 255).astype(np.uint8)
        
        skel_coords = np.argwhere(skeleton)
        
        if len(skel_coords) == 0:
            return None
            
        middle_idx = len(skel_coords) // 2
        target_y, target_x = skel_coords[middle_idx]
        
        return (int(target_x), int(target_y)), skeleton_img, 0
    except:
        return None

def measure_width_along_normal(mask_uint8, x, y, normal_angle, max_search=100):
    """
    沿法线方向测量局部宽度
    """
    height, width = mask_uint8.shape
    
    # 法线方向向量
    nx = math.cos(normal_angle)
    ny = math.sin(normal_angle)
    
    # 向两侧搜索边界
    def find_boundary(dx_dir, dy_dir):
        step = 0
        while step < max_search:
            check_x = int(x + dx_dir * step)
            check_y = int(y + dy_dir * step)
            
            if check_x < 0 or check_x >= width or check_y < 0 or check_y >= height:
                return step
            
            if mask_uint8[check_y, check_x] == 0:
                return step - 1 if step > 0 else 0
                
            step += 1
        return max_search
    
    # 正反方向搜索
    dist1 = find_boundary(nx, ny)
    dist2 = find_boundary(-nx, -ny)
    
    return dist1 + dist2

# ================= 📷 相机类 (增加报错透传与重试机制) =================
class AsyncAstraCamera:
    def __init__(self, lib_path):
        self.valid = False
        self.running = False
        self.color_frame = None
        self.depth_frame = None
        self.lock = threading.Lock()
        self.thread = None
        
        for i in range(3):
            try:
                try: openni2.unload()
                except: pass
                
                openni2.initialize(lib_path)
                self.dev = openni2.Device.open_any()
                
                self.color_stream = self.dev.create_color_stream()
                self.depth_stream = self.dev.create_depth_stream()
                self.dev.set_image_registration_mode(openni2.IMAGE_REGISTRATION_DEPTH_TO_COLOR)
                self.dev.set_image_registration_mode(openni2.IMAGE_REGISTRATION_DEPTH_TO_COLOR)
                
                self.color_stream.start()
                self.depth_stream.start()
                
                self.valid = True
                self.running = True
                self.thread = threading.Thread(target=self._update_frames, daemon=True)
                self.thread.start()
                print("✅ Astra相机初始化成功，等待画面流入...")
                break
            except Exception as e:
                print(f"⚠️ 初始化失败: {e}")
                time.sleep(1.5)

        if not self.valid:
            print("❌ 错误：无法连接相机。")

    def _update_frames(self):
        print("🎥 相机取流后台线程已启动...")
        error_count = 0
        while self.running:
            try:
                c = self.color_stream.read_frame()
                d = self.depth_stream.read_frame()
                c_img = np.frombuffer(c.get_buffer_as_uint8(), dtype=np.uint8).reshape(c.height, c.width, 3)
                c_img = cv2.cvtColor(c_img, cv2.COLOR_RGB2BGR)
                d_img = np.frombuffer(d.get_buffer_as_uint16(), dtype=np.uint16).reshape(d.height, d.width)
                with self.lock:
                    self.color_frame = c_img
                    self.depth_frame = d_img
                error_count = 0 # 成功读取，重置错误计数
            except Exception as e:
                error_count += 1
                if error_count % 30 == 0:  # 防止刷屏，每隔一段时间打印一次
                    print(f"⚠️ 警告：相机未能传输画面数据 (可能USB供电不足) -> {e}")
            time.sleep(0.01)

    def get_frames(self):
        with self.lock:
            if self.color_frame is not None:
                return self.color_frame.copy(), self.depth_frame.copy()
            return None, None

    def stop(self):
        self.running = False
        if self.thread: self.thread.join(timeout=1)
        try:
            openni2.unload()
        except: pass

