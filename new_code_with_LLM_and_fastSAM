    """带重试机制的机械臂指令发送"""
    params = {'x': round(float(x), 2), 'y': round(float(y), 2), 
              'z': round(float(z), 2), 'c': int(claw), 't': int(t)}
    timeout_val = (t / 1000.0) + 1.0 
    
    for attempt in range(1, max_retries + 1):
        try:
            resp = http_session.get(ROBOT_URL, params=params, timeout=timeout_val)
            if resp.status_code == 200:
                return True
        except requests.exceptions.RequestException:
            print(f"[通信警告] 指令 {params} 超时，正在重试 ({attempt}/{max_retries})...")
            time.sleep(0.2)
    return False

def grab_sequence(rx, ry, rz):
    """执行完整的抓取序列"""
    global robot_busy
    robot_busy = True
    OPEN, CLOSE = 100, 6
    print(f"\n🚀 开始执行 3D 抓取: X:{rx:.1f} Y:{ry:.1f} Z:{rz:.1f}")
    
    steps = [
        ("悬停对准", rx, -ry, HOVER_Z, OPEN, 1200),
        ("下降抓取", rx, -ry, rz, OPEN, 800),
        ("闭合机械爪", rx, -ry, rz, CLOSE, 500),
        ("垂直拉升", rx, -ry, HOVER_Z, CLOSE, 800),
        ("移动至投放点", 15.0, -15.0, HOVER_Z, CLOSE, 1200),
        ("松开物体", 15.0, -15.0, HOVER_Z, OPEN, 500),
        ("归位待命", 5.0, 0.0, HOVER_Z, OPEN, 1000)
    ]
    
    for action, x, y, z, c, t in steps:
        print(f" > {action}...")
        if not blocking_send(x, y, z, c, t):
            print("!!! 严重错误：重试失败，动作序列被强制终止。")
            break
        # 守护线程中的延时，不会卡死主界面的摄像头和识别
        time.sleep((t / 1000.0) + 0.1) 
    
    print("✅ 抓取流程结束\n")
    robot_busy = False

# ================= 🔍 智能搜索函数 (整合第三段代码) =================
def smart_search_and_grab(user_command, color_frame, depth_frame, masks_list):
    """
    智能搜索逻辑：
    1. 数量检测：如果是0个，直接报错。
    2. 预处理：过滤小物体，按距离中心排序。
    3. 逐个询问：调用大模型，一旦确认，立即抓取并停止。
    """
    global robot_busy
    
    if robot_busy:
        print("⚠️ 机械臂正忙，请等待当前任务完成")
        return
    
    # --- 1. 判空处理 ---
    if len(masks_list) == 0:
        print("👀 画面空空如也，没看到任何能抓的东西！")
        return

    print(f"🧐 FastSAM 发现了 {len(masks_list)} 个物体，正在筛选...")

    # 获取画面中心点
    h, w = color_frame.shape[:2]
    center_x, center_y = w // 2, h // 2

    # --- 2. 智能排序与过滤 ---
    candidates = []
    for obj in masks_list:
        # 计算面积
        bbox = obj['bbox']
        area = bbox[2] * bbox[3]  # 宽 * 高
        
        # 过滤1：太小的噪点不要
        if area < 1500: 
            continue 
            
        # 计算物体中心到画面中心的距离
        cx, cy = obj['center']
        dist_to_center = math.hypot(cx - center_x, cy - center_y)
        
        # 将整理好的数据存入临时列表
        candidates.append({
            'obj': obj,
            'dist': dist_to_center,
            'area': area
        })

    # 排序：优先看离中心最近的物体
    candidates.sort(key=lambda x: x['dist'])

    print(f"🔍 筛选后剩余 {len(candidates)} 个有效候选物体，开始AI识别...")

    # --- 3. 逐个询问大模型 ---
    target_obj = None
    
    # 限制最大尝试次数
    max_attempts = min(len(candidates), 10)
    
    for i in range(max_attempts):
        candidate = candidates[i]
        obj = candidate['obj']
        
        # 在屏幕上画框，让用户知道 AI 正在看哪个
        debug_img = color_frame.copy()
        x, y, w, h = obj['bbox']
        cv2.rectangle(debug_img, (x, y), (x+w, y+h), (0, 255, 0), 3)
        cv2.putText(debug_img, f"Checking #{i+1}...", (x, y-10), 0, 0.8, (0, 255, 0), 2)
        cv2.imshow("AI_Vision", debug_img)
        cv2.waitKey(50)  # 稍微停顿展示一下

        # 截取该物体的图片
        crop_img = obj['crop'] 
        
        print(f"🤖 正在分析第 {i+1} 个物体 (距离中心 {int(candidate['dist'])}px)...")
        
        # 询问大模型
        is_match = ask_ai_what_is_this(crop_img, user_command)
        
        if is_match:
            print(f"✅ 找到了！目标锁定：候选物体 #{i+1}")
            target_obj = obj
            break  # 找到了就立刻退出循环

    # --- 4. 结果处理 ---
    if target_obj:
        # 计算目标坐标（使用抓取点或中心点）
        if 'grasp_point' in target_obj:
            cx, cy = target_obj['grasp_point']
        else:
            cx, cy = target_obj['center']
            
        coords = pixel_to_robot_xyz(cx, cy, depth_frame)
        
        if coords:
            rx, ry, rz = coords
            # 启动抓取线程
            threading.Thread(target=grab_sequence, args=(rx, ry, rz), daemon=True).start()
        else:
            print("❌ 无法计算目标坐标")
    else:
        print("🤷‍♂️ 看了几个最可能的物体，都没找到你要的。请尝试把物体放中间一点，或者说得更清楚些。")

