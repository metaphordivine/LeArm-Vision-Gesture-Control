def submit_calibration_feedback(dx, dy, dz):
    """接收一次预抓取反馈并更新映射模型。"""
    global calibration_count, pending_calibration_sample, calibration_waiting_feedback
    global calibration_status_text, calibration_feedback_pending

    with calibration_lock:
        calibration_feedback_pending = False
        if pending_calibration_sample is None:
            return False, "当前没有等待反馈的预抓取样本。"

        offset_xyz = (float(dx), float(dy), float(dz))
        raw_xyz = tuple(pending_calibration_sample['raw_xyz'])
        success_xyz = build_success_xyz(raw_xyz, offset_xyz)
        sample = {
            **pending_calibration_sample,
            'offset_xyz': offset_xyz,
            'success_xyz': success_xyz,
            'submitted_at': time.time(),
        }
        calibration_samples.append(sample)
        calibration_count = len(calibration_samples)
        pending_calibration_sample = None
        calibration_waiting_feedback = False

        print(
            f"📍 校准样本 {calibration_count}/{PREGRAB_SAMPLE_COUNT} | raw={tuple(round(v, 2) for v in raw_xyz)} "
            f"offset={tuple(round(v, 2) for v in offset_xyz)} success={tuple(round(v, 2) for v in success_xyz)}"
        )

        if calibration_count >= PREGRAB_SAMPLE_COUNT:
            fitted = fit_success_mapping_model()
            if fitted:
                finish_pregrab_calibration()
                return True, calibration_status_text
            calibration_status_text = "16次样本已完成，但拟合失败，请按 r 重置后重试。"
            return False, calibration_status_text

        calibration_status_text = (
            f"已记录 {calibration_count}/{PREGRAB_SAMPLE_COUNT} 次。点击下一个目标继续预抓取。"
        )
        return True, calibration_status_text


def handle_calibration_feedback_queue():
    """在主循环中处理网页提交的偏移反馈。"""
    processed = False
    while True:
        try:
            dx, dy, dz = calibration_feedback_queue.get_nowait()
        except queue.Empty:
            break

        processed = True
        ok, message = submit_calibration_feedback(dx, dy, dz)
        prefix = "✅" if ok else "⚠️"
        print(f"{prefix} {message}")
    return processed


