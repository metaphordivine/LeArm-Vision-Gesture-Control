# ================= 🎛️ 新增：校正窗口函数 =================
def create_calibration_window():
    """创建坐标校正窗口"""
    global offset_x, offset_y, offset_z
    
    cv2.namedWindow("adjust", cv2.WINDOW_NORMAL)
    cv2.resizeWindow("adjust", 500, 400)
    
    # 创建滑动条
    # X轴偏移 (-10.0cm 到 +10.0cm，步长0.1cm)
    cv2.createTrackbar("Xoffset(cm)", "adjust", int((offset_x + 10.0) * 10), 200, lambda x: None)
    # Y轴偏移 (-10.0cm 到 +10.0cm，步长0.1cm)
    cv2.createTrackbar("Yoffset(cm)", "adjust", int((offset_y + 10.0) * 10), 200, lambda x: None)
    # Z轴偏移 (-10.0cm 到 +10.0cm，步长0.1cm)
    cv2.createTrackbar("Zoffset(cm)", "adjust", int((offset_z + 10.0) * 10), 200, lambda x: None)
    
    # 恢复默认值按钮
    print("✅ 校正窗口已创建，可以调节X,Y,Z轴的偏移量")

def update_calibration_values():
    """从滑动条读取并更新校正值"""
    global offset_x, offset_y, offset_z
    
    try:
        # 读取滑动条值并转换为浮点数 (滑动条范围0-200对应-10.0到+10.0)
        offset_x = (cv2.getTrackbarPos("Xoffset(cm)", "adjust") / 10.0) - 10.0
        offset_y = (cv2.getTrackbarPos("Yoffset(cm)", "adjust") / 10.0) - 10.0
        offset_z = (cv2.getTrackbarPos("Zoffset(cm)", "adjust") / 10.0) - 10.0
    except:
        pass  # 窗口可能还未创建

def draw_calibration_display():
    """在图片上显示当前的校正值"""
    global offset_x, offset_y, offset_z, last_z_error, calibrating, calibration_count, calibration_max
    global calibration_waiting_feedback, calibration_status_text, calibration_model_summary
    line1 = f"offset: X:{offset_x:+.1f}cm Y:{offset_y:+.1f}cm Z:{offset_z:+.1f}cm"
    line2 = f"auto Z corr: {last_z_error:+.2f}cm"
    if calibrating:
        wait_suffix = " waiting dx dy dz" if calibration_waiting_feedback else " click next target"
        line3 = f"CALIB: {calibration_count}/{calibration_max}{wait_suffix}"
    else:
        line3 = calibration_model_summary if calibration_model is not None else ""
    line4 = calibration_status_text[:80] if calibration_status_text else ""
    return line1, line2, line3, line4

# ================= 🚀 主程序 (防崩溃优化版，集成Z轴自动校正) =================
def main():
    global detected_masks, latest_depth_frame, robot_busy, DEVICE, USE_SKELETON_GRASP
    
    # 🌟 优化1：先加载重型 AI 模型，防止后续多线程抢占资源崩溃
    print("⏳ [步骤 1/3] 正在加载 AI 模型到显卡 (需等待几秒)...")
    try:
        model = FastSAM('FastSAM-s.pt')
        model.to(DEVICE)
        print(f"✅ FastSAM 模型已成功加载到 ({DEVICE})")
    except Exception as e:
        print(f"❌ 模型加载失败: {e}")
        return

    # 🌟 优化2：启动 Flask 服务器
    print("⏳[步骤 2/3] 正在启动语音服务器...")
    threading.Thread(target=run_flask, daemon=True).start()
    print("📱 语音服务可用: http://192.168.43.5:5000")
    
    # 🌟 优化3：最后再启动最容易出错的相机硬件
    print("⏳ [步骤 3/3] 正在连接 Astra 3D 相机...")
    cam = AsyncAstraCamera(OPENNI_LIB_PATH)
    if not cam.valid: 
        print("\n" + "="*50)
        print("🚨 致命错误：相机底层死锁！")
        print("🚨 请立即执行以下操作：")
        print("🚨 1. 拔掉 Astra 相机的 USB 线。")
        print("🚨 2. 等待 5 秒钟。")
        print("🚨 3. 重新插上 USB 线。")
        print("🚨 4. 再次运行程序。")
        print("="*50 + "\n")
        return
    
    # 🌟 新增：创建校正窗口
    create_calibration_window()
    
    # 创建主窗口
    cv2.namedWindow("AI_Vision", cv2.WINDOW_NORMAL)
    cv2.setMouseCallback("AI_Vision", mouse_callback)
    cv2.createTrackbar("Conf", "AI_Vision", 65, 95, lambda x: None)
    
    print("\n=== ⚡ 系统已全部就绪 ⚡ ===")
    
    try:
        while True:
            # 1. 窗口安全检查
            if cv2.getWindowProperty("AI_Vision", cv2.WND_PROP_VISIBLE) < 1: 
                print("🛑 检测到窗口关闭，准备退出...")
                break
            
            # 更新校正值
            update_calibration_values()
            
            # 2. 获取画面
            color_img, depth_img = cam.get_frames()
            if color_img is None:
                # 创一个黑屏提示用户，而不是卡死窗口
                black_screen = np.zeros((480, 640, 3), dtype=np.uint8)
                cv2.putText(black_screen, "Waiting for Camera Signal...", (50, 240), 
                            cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 0, 255), 2)
                cv2.imshow("AI_Vision", black_screen)
                
                key = cv2.waitKey(50)
                if key == ord('q') or key == 27: break
                continue
                
            latest_depth_frame = depth_img
            
            # 3. 运行检测 (当机械臂没在动时)
            if not robot_busy:
                try:
                    conf_thresh = cv2.getTrackbarPos("Conf", "AI_Vision") / 100.0
                except cv2.error:
                    conf_thresh = 0.65

                results = model(color_img, device=DEVICE, retina_masks=True, 
                              conf=conf_thresh, iou=0.8, verbose=False, imgsz=640)
                
                detected_masks = []
                if len(results) > 0 and results[0].masks is not None:
                    # 1. 获取画面总面积并设定比例限制
                    img_h, img_w = color_img.shape[:2]
                    total_area = img_h * img_w
                    max_area_limit = total_area / 10.0
                    min_area_limit = total_area / 500.0
                    
                    masks = results[0].masks.data.cpu().numpy()
                    for mask in masks:
                        # 2. 🎯【过滤机制 1：面积过滤】
                        if np.sum(mask) > max_area_limit or np.sum(mask) < min_area_limit:
                            continue
                            
                        mask_uint8 = (mask * 255).astype(np.uint8)
                        
                        # 计算物体中心点（默认使用距离变换中心）
                        dist_trans = cv2.distanceTransform(mask_uint8, cv2.DIST_L2, 5)
                        _, _, _, max_loc = cv2.minMaxLoc(dist_trans)
                        default_cx, default_cy = max_loc
                        
                        # 初始化抓取点为中心点
                        grasp_cx, grasp_cy = default_cx, default_cy
                        skeleton_img = None
                        
                        if USE_SKELETON_GRASP:
                            # 尝试使用骨架化方法
                            skeleton_result = get_skeleton_grasp_pose_advanced(mask_uint8, GRIPPER_MAX_WIDTH_PIXELS)
                            if skeleton_result:
                                (grasp_cx, grasp_cy), skeleton_img, local_width = skeleton_result
                                # 不再打印到控制台，只在图像上显示
                            else:
                                # 骨架化失败，使用默认中心点
                                grasp_cx, grasp_cy = default_cx, default_cy
                        
                        # 3. 🎯【过滤机制 2：高度/深度过滤】
                        if table_depth_val > 0 and depth_img is not None:
                            obj_depth = get_robust_region_depth(depth_img, grasp_cx, grasp_cy)
                            
                            if obj_depth > 0 and obj_depth > (table_depth_val + 15):
                                continue  # 如果物体比桌面还要低 1.5cm 以上，直接作为噪点丢弃！
                        
                        # 经过重重过滤，真正有效的目标才会被记录
                        contours, _ = cv2.findContours(mask_uint8, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
                        if contours:
                            x, y, w, h = cv2.boundingRect(contours[0])
                            crop = color_img[y:y+h, x:x+w] if y+h < color_img.shape[0] and x+w < color_img.shape[1] else None
                            
                            obj_data = {
                                'mask': mask_uint8, 
                                'center': (default_cx, default_cy),  # 原始中心点
                                'grasp_point': (grasp_cx, grasp_cy),  # 抓取点（可能是骨架化结果）
                                'bbox': (x, y, w, h), 
                                'crop': crop
                            }
                            
                            # 保存骨架图像用于显示
                            if skeleton_img is not None:
                                obj_data['skeleton'] = skeleton_img
                                
                            detected_masks.append(obj_data)
            
            # 4. 处理语音指令
            try:
                cmd_text = cmd_queue.get_nowait()
                if state == 3 and not robot_busy and not calibrating and cmd_text:
                    threading.Thread(target=smart_search_and_grab, 
                                   args=(cmd_text, color_img, depth_img, detected_masks), 
                                   daemon=True).start()
                elif cmd_text:
                    print("⏸️ 当前不接受语音抓取，需先完成初始化校准。")
            except queue.Empty:
                pass

            handle_calibration_feedback_queue()
            
            # 5. 渲染画面
            display_img = color_img.copy()
            
            # 创建骨架叠加层（半透明）
            skeleton_overlay = np.zeros_like(display_img)
            
            for i, obj in enumerate(detected_masks):
                # 物体颜色
                color = ((i*40)%255, (i*80)%255, 255 - (i*30)%255)
                
                # 绘制物体轮廓
                contours, _ = cv2.findContours(obj['mask'], cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
                if contours:
                    cv2.drawContours(display_img, contours, -1, color, 1)
                
                # 绘制边界框
                x, y, w, h = obj['bbox']
                cv2.rectangle(display_img, (x, y), (x+w, y+h), color, 1)
                
                # 如果有骨架图像，叠加显示（半透明青色）
                if 'skeleton' in obj:
                    skeleton = obj['skeleton']
                    # 将骨架转换为彩色
                    skeleton_color = np.zeros_like(display_img)
                    skeleton_color[:, :, 0] = 255  # 蓝色通道
                    skeleton_color[:, :, 1] = 255  # 绿色通道（合成为青色）
                    skeleton_color[:, :, 2] = 0    # 红色通道
                    
                    # 只显示骨架区域
                    skeleton_mask = skeleton > 0
                    for c in range(3):
                        skeleton_overlay[:, :, c] = np.where(skeleton_mask, 
                                                           skeleton_color[:, :, c], 
                                                           skeleton_overlay[:, :, c])
                
                # 绘制抓取点（红色圆圈）
                if 'grasp_point' in obj:
                    gx, gy = obj['grasp_point']
                    # 红色圆圈标记抓取点
                    cv2.circle(display_img, (gx, gy), 8, (0, 0, 255), 2)  # 红色外圈
                    cv2.circle(display_img, (gx, gy), 4, (0, 0, 255), -1)  # 红色实心
                    
                    # 计算并显示3D坐标
                    if state in (2, 3) and depth_img is not None and table_depth_val > 0:
                        raw_coords = pixel_to_robot_raw_xyz(gx, gy, depth_img)
                        if raw_coords:
                            raw_x, raw_y, raw_z = raw_coords
                            success_x, success_y, success_z = apply_calibrated_mapping(raw_coords)
                            # 在抓取点附近显示3D坐标
                            if state == 2:
                                coord_text = f"RAW X:{raw_x:.1f} Y:{raw_y:.1f} Z:{raw_z:.1f}"
                            else:
                                coord_text = f"OK X:{success_x:.1f} Y:{success_y:.1f} Z:{success_z:.1f}"
                            text_bg_y = gy - 60 if gy > 60 else gy + 20
                            # 绘制文本背景
                            text_size = cv2.getTextSize(coord_text, cv2.FONT_HERSHEY_SIMPLEX, 0.5, 1)[0]
                            cv2.rectangle(display_img, 
                                        (gx - text_size[0]//2 - 5, text_bg_y - text_size[1] - 5),
                                        (gx + text_size[0]//2 + 5, text_bg_y + 5),
                                        (0, 0, 0), -1)
                            # 绘制坐标文本
                            cv2.putText(display_img, coord_text, 
                                      (gx - text_size[0]//2, text_bg_y), 
                                      cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255, 255, 255), 1)
                
                # 显示物体高度信息（在原始中心点）
                cx, cy = obj['center']
                if table_depth_val > 0 and depth_img is not None:
                    d_mm = get_robust_region_depth(depth_img, cx, cy)
                    if d_mm > 0:
                        h_cm = max(0, (table_depth_val - d_mm) / 10.0)
                        cv2.putText(display_img, f"Z:{h_cm:.1f}cm", (cx-20, cy-15), 
                                    cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255, 255, 255), 1)
            
            # 半透明叠加骨架层
            if np.any(skeleton_overlay > 0):
                # 骨架显示为半透明青色
                cv2.addWeighted(skeleton_overlay, 0.3, display_img, 1.0, 0, display_img)
            
            # 绘制标定点
            for pt in calib_points: 
                cv2.circle(display_img, pt, 6, (255, 255, 0), -1)
            
            # 绘制底座原点
            if base_point_pixel: 
                cv2.drawMarker(display_img, base_point_pixel, (255, 0, 255), cv2.MARKER_CROSS, 20, 3)
            
            # 添加校正值显示
            calib_line1, calib_line2, calib_line3, calib_line4 = draw_calibration_display()
            cv2.putText(display_img, calib_line1, (15, 30), 
                       cv2.FONT_HERSHEY_SIMPLEX, 0.6, (255, 255, 0), 2)
            cv2.putText(display_img, calib_line2, (15, 55), 
                       cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 255), 2)
            if calib_line3:
                cv2.putText(display_img, calib_line3, (15, 80), 
                           cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 255), 2)
            if calib_line4:
                cv2.putText(display_img, calib_line4, (15, 105), 
                           cv2.FONT_HERSHEY_SIMPLEX, 0.55, (180, 255, 180), 1)

            ai_overlay = get_ai_inspection_overlay()
            if ai_overlay:
                x, y, w, h = ai_overlay['bbox']
                label = ai_overlay['text']
                cv2.rectangle(display_img, (x, y), (x + w, y + h), (0, 255, 0), 3)
                if label:
                    text_y = y - 12 if y > 24 else y + h + 24
                    cv2.putText(display_img, label, (x, text_y), 
                               cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 255, 0), 2)
            
            draw_hud(display_img, state, robot_busy)
            cv2.imshow("AI_Vision", display_img)
            
            # 显示校正窗口
            if cv2.getWindowProperty("adjust", cv2.WND_PROP_VISIBLE) >= 1:
                # 创建校正窗口显示图像
                calib_display = np.zeros((200, 500, 3), dtype=np.uint8)
                calib_display[:] = (40, 40, 40)  # 深灰色背景
                
                # 显示当前值
                text = f"Xoffset: {offset_x:+.1f} cm"
                cv2.putText(calib_display, text, (20, 40), 
                           cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 255, 255), 2)
                
                text = f"Yoffset: {offset_y:+.1f} cm"
                cv2.putText(calib_display, text, (20, 80), 
                           cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 255, 255), 2)
                
                text = f"Zoffset: {offset_z:+.1f} cm"
                cv2.putText(calib_display, text, (20, 120), 
                           cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 255, 255), 2)
                
                cv2.putText(calib_display, "adjust offsets", (20, 170), 
                           cv2.FONT_HERSHEY_SIMPLEX, 0.6, (255, 255, 255), 1)
                
                cv2.imshow("adjust", calib_display)
            
            key = cv2.waitKey(1)
            if key == ord('q') or key == 27: break
            elif key == ord('r'): reset_system()
            elif key == ord('s'):  # 切换骨架化开关
                USE_SKELETON_GRASP = not USE_SKELETON_GRASP
                print(f"切换骨架化: {'ON' if USE_SKELETON_GRASP else 'OFF'}")

    finally:
        print("\n[安全退出] 正在清理所有硬件资源...")
        try:
            cam.stop()
        except:
            pass
        cv2.destroyAllWindows()
        print("👋 程序已安全退出")

if __name__ == "__main__":
    main()
