        ai_inspection_overlay = {
            'bbox': (int(x), int(y), int(w), int(h)),
            'text': text,
        }


def get_ai_inspection_overlay():
    with ai_inspection_overlay_lock:
        if ai_inspection_overlay is None:
            return None
        return dict(ai_inspection_overlay)

def mouse_callback(event, x, y, flags, param):
    """鼠标回调：整合标定与手动抓取功能"""
    global state, calib_points, base_point_pixel, base_pos_world
    global matrix_pixel_to_world, table_depth_val, robot_busy, latest_depth_frame
    global calibrating, calibration_count
    
    if event == cv2.EVENT_LBUTTONDOWN:
        if state == 0:  # 标定阶段：点击A4纸四个角
            calib_points.append((x, y))
            print(f"标定点 {len(calib_points)}: ({x}, {y})")
            if len(calib_points) == 4:
                pts_src = np.float32(calib_points)
                pts_dst = np.float32([[0, CALIB_HEIGHT], [0, 0], 
                                      [CALIB_WIDTH, 0], [CALIB_WIDTH, CALIB_HEIGHT]])
                matrix_pixel_to_world = cv2.getPerspectiveTransform(pts_src, pts_dst)
                
                # 计算桌面基准深度值
                if latest_depth_frame is not None:
                    ds = [get_robust_region_depth(latest_depth_frame, p[0], p[1]) for p in calib_points]
                    valid_ds = [d for d in ds if d > 0]
                    table_depth_val = np.mean(valid_ds) if valid_ds else 0
                    print(f"桌面深度基准值: {table_depth_val:.1f} mm")
                
                state = 1
                print("\n>>> 标定纸设定完毕。请点击[机械臂底座]设定原点。")
                
        elif state == 1:  # 点击底座原点
            base_point_pixel = (x, y)
            vec = np.array([[[x, y]]], dtype=np.float32)
            base_pos_world = cv2.perspectiveTransform(vec, matrix_pixel_to_world)[0][0]
            start_pregrab_calibration()
            print(f"\n>>> 系统已完全就绪！底座原点: {base_pos_world}")
            print("🚧 进入初始化 16 次预抓取校准模式。")
            print("    每次点击一个目标，系统先按 raw_xyz 执行预抓取。")
            print("    抓取结束后，请在 Flask 网页输入 dx dy dz，系统将计算 success_xyz = raw_xyz + offset_xyz。")
            print("    16次样本完成后，系统会自动拟合 raw_xyz -> success_xyz 映射并进入常规模式。")
            print(">>> 另外：")
            print("    1. 校准完成前，语音抓取与普通点击抓取会被锁定。")
            print("    2. 校准完成后，再使用手机语音或鼠标抓取。")
            
        elif state in (2, 3) and not robot_busy:  # 校准或就绪状态
            if calibrating and calibration_waiting_feedback:
                print("⏳ 当前正在等待网页输入上一抓的 dx dy dz，请先提交偏移量。")
                return

            # 寻找最近的物体
            best_obj = None
            min_dist = 50  # 像素距离阈值
            for obj in detected_masks:
                if 'grasp_point' in obj:
                    cx, cy = obj['grasp_point']
                else:
                    cx, cy = obj['center']
                d = math.hypot(cx - x, cy - y)
                if d < min_dist:
                    min_dist, best_obj = d, obj
            
            if best_obj:
                if 'grasp_point' in best_obj:
                    cx, cy = best_obj['grasp_point']
                else:
                    cx, cy = best_obj['center']
                raw_coords = pixel_to_robot_raw_xyz(cx, cy, latest_depth_frame)
                if raw_coords:
                    rx, ry, rz = raw_coords
                    if rx > 5.0:
                        if calibrating:
                            threading.Thread(
                                target=launch_calibration_pregrab,
                                args=((rx, ry, rz), (x, y), (cx, cy)),
                                daemon=True,
                            ).start()
                        else:
                            success_coords = apply_calibrated_mapping((rx, ry, rz))
                            threading.Thread(target=grab_sequence, args=success_coords, daemon=True).start()
                    else:
                        print(">>> ⚠️ 目标太靠近基座，系统拒绝执行以防止碰撞。")
                else:
                    print(">>> ❌ 无法计算目标坐标")
            # 如果正在校准，不继续执行正常抓取逻辑
            if calibrating:
                return

