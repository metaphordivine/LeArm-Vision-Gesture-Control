# ================= 📐 坐标与深度计算 (鲁棒性升级，集成Z轴自动校正) =================
def get_robust_region_depth(depth_img, x, y, radius=4):
    """带抗噪滤波的深度提取"""
    h, w = depth_img.shape
    y_min, y_max = max(0, int(y-radius)), min(h, int(y+radius+1))
    x_min, x_max = max(0, int(x-radius)), min(w, int(x+radius+1))
    roi = depth_img[y_min:y_max, x_min:x_max]
    
    valid = roi[roi > 0]
    if len(valid) > 3:
        # 去除极值噪点，取中位数附近的均值
        p20, p80 = np.percentile(valid, 20), np.percentile(valid, 80)
        filtered = valid[(valid >= p20) & (valid <= p80)]
        return np.mean(filtered) if len(filtered) > 0 else np.median(valid)
    return 0

def pixel_to_robot_raw_xyz(u, v, depth_frame):
    """像素坐标转机械臂原始坐标，不叠加16点校准映射。"""
    global matrix_pixel_to_world, base_pos_world, table_depth_val
    global last_z_error
    
    if matrix_pixel_to_world is None or depth_frame is None:
        return None
    
    vec = np.array([[[u, v]]], dtype=np.float32)
    world_pos = cv2.perspectiveTransform(vec, matrix_pixel_to_world)[0][0]
    raw_x = world_pos[0] - base_pos_world[0]  # 原始X坐标（未加偏移）
    raw_y = world_pos[1] - base_pos_world[1]  # 原始Y坐标（未加偏移）
    
    obj_depth_mm = get_robust_region_depth(depth_frame, u, v)
    if obj_depth_mm > 0 and table_depth_val > 0:
        obj_height_cm = (table_depth_val - obj_depth_mm) / 10.0
        rob_z = max(TABLE_BASE_Z, TABLE_BASE_Z + obj_height_cm)
    else:
        rob_z = TABLE_BASE_Z+6.0  # 默认高度，避免过低
    
    if ENABLE_LEGACY_Z_CORRECTION and coefficients is not None:
        z_error = compute_z_error(raw_x, raw_y)
        rob_z -= z_error  # 减去系统误差
        last_z_error = z_error
    else:
        last_z_error = 0.0

    return raw_x, raw_y, rob_z


def pixel_to_robot_xyz(u, v, depth_frame):
    """像素坐标转机械臂抓取坐标（raw_xyz -> success_xyz）。"""
    raw_xyz = pixel_to_robot_raw_xyz(u, v, depth_frame)
    if raw_xyz is None:
        return None
    return apply_calibrated_mapping(raw_xyz)

