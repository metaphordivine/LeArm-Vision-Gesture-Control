def _to_xyz_array(values):
    return np.asarray(values, dtype=np.float64)


def build_success_xyz(raw_xyz, offset_xyz):
    """根据用户输入的偏移量计算可成功抓取坐标。"""
    return tuple((_to_xyz_array(raw_xyz) + _to_xyz_array(offset_xyz)).tolist())


def compute_modified_zscores(values):
    """基于MAD计算鲁棒z-score。"""
    values = np.asarray(values, dtype=np.float64)
    if values.ndim == 1:
        values = values[:, None]
    median = np.median(values, axis=0)
    mad = np.median(np.abs(values - median), axis=0)
    mad = np.where(mad < 1e-6, 1.0, mad)
    return 0.6745 * (values - median) / mad


def filter_calibration_samples(samples):
    """过滤明显异常的偏移输入，避免污染映射模型。"""
    if len(samples) <= 4:
        return samples, np.arange(len(samples))

    offsets = np.array([sample['offset_xyz'] for sample in samples], dtype=np.float64)
    scores = np.abs(compute_modified_zscores(offsets))
    mask = np.all(scores < 3.5, axis=1)

    if np.count_nonzero(mask) < max(8, len(samples) // 2):
        mask = np.ones(len(samples), dtype=bool)

    kept_indices = np.nonzero(mask)[0]
    filtered = [samples[index] for index in kept_indices]
    return filtered, kept_indices


def build_polynomial_features(points):
    """为三维坐标构造二次多项式特征。"""
    points = np.asarray(points, dtype=np.float64)
    x = points[:, 0]
    y = points[:, 1]
    z = points[:, 2]
    return np.column_stack([
        np.ones(len(points)),
        x, y, z,
        x * x, y * y, z * z,
        x * y, x * z, y * z,
    ])


def fit_ridge_mapping(raw_points, success_points, ridge_alpha=1e-3):
    """使用带L2正则的二次多项式做回退拟合。"""
    features = build_polynomial_features(raw_points)
    eye = np.eye(features.shape[1], dtype=np.float64)
    eye[0, 0] = 0.0
    try:
        coeffs = np.linalg.solve(features.T @ features + ridge_alpha * eye, features.T @ success_points)
    except np.linalg.LinAlgError:
        coeffs, *_ = np.linalg.lstsq(features, success_points, rcond=None)
    predictions = features @ coeffs
    return {
        'type': 'ridge',
        'coeffs': coeffs,
        'ridge_alpha': ridge_alpha,
        'predictions': predictions,
    }


def fit_success_mapping_model():
    """基于 raw_xyz -> success_xyz 拟合映射模型。"""
    global calibration_model, calibration_model_summary, offset_coeffs_x, offset_coeffs_y, offset_coeffs_z

    if len(calibration_samples) < PREGRAB_SAMPLE_COUNT:
        calibration_model = None
        calibration_model_summary = f"样本不足 {len(calibration_samples)}/{PREGRAB_SAMPLE_COUNT}"
        return False

    filtered_samples, kept_indices = filter_calibration_samples(calibration_samples)
    raw_points = np.array([sample['raw_xyz'] for sample in filtered_samples], dtype=np.float64)
    success_points = np.array([sample['success_xyz'] for sample in filtered_samples], dtype=np.float64)

    if len(raw_points) < 8:
        calibration_model = None
        calibration_model_summary = f"有效样本不足: {len(raw_points)}/{len(calibration_samples)}"
        return False

    model = None
    predictions = None
    try:
        from scipy.interpolate import RBFInterpolator

        offset_norm = np.linalg.norm(success_points - raw_points, axis=1)
        smoothing = max(0.05, float(np.median(offset_norm)) * 0.05)
        models = [
            RBFInterpolator(raw_points, success_points[:, axis], kernel='thin_plate_spline', smoothing=smoothing)
            for axis in range(3)
        ]
        predictions = np.column_stack([
            models[axis](raw_points).reshape(-1) for axis in range(3)
        ])
        model = {
            'type': 'rbf',
            'models': models,
            'smoothing': smoothing,
            'predictions': predictions,
        }
    except Exception as error:
        print(f"⚠️ RBF拟合不可用，回退到Ridge模型: {error}")
        model = fit_ridge_mapping(raw_points, success_points)
        predictions = model['predictions']

    residuals = np.linalg.norm(predictions - success_points, axis=1)
    calibration_model = {
        **model,
        'raw_points': raw_points,
        'success_points': success_points,
        'kept_indices': kept_indices.tolist(),
        'mean_residual': float(np.mean(residuals)),
        'max_residual': float(np.max(residuals)),
        'valid_count': int(len(raw_points)),
        'total_count': int(len(calibration_samples)),
    }
    calibration_model_summary = (
        f"{calibration_model['type'].upper()} ready | valid {calibration_model['valid_count']}/"
        f"{calibration_model['total_count']} | mean {calibration_model['mean_residual']:.2f}cm | "
        f"max {calibration_model['max_residual']:.2f}cm"
    )

    offset_coeffs_x = None
    offset_coeffs_y = None
    offset_coeffs_z = None
    print(f"✅ 校准映射模型已更新: {calibration_model_summary}")
    return True


def apply_calibrated_mapping(raw_xyz):
    """把原始抓取坐标映射到成功抓取坐标。"""
