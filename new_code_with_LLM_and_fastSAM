# ================= 📊 Z轴自动校正拟合 =================
# 用户提供的标定数据集 (x, y, z) 单位：cm
# 第一行 (16.4, -2.9, 9.1) 为标准参考点
CALIBRATION_DATA = [    #替换为你的误差测量
    (16.4, -2.9, 9.1),   # 标准数据，正常抓取
    (8.0, -1.7, 9.1),
    (25.5, -2.7, 9.1),
    (16.5, -7.9, 8.8),
    (25.5, -10.4, 8.8),
    (26.0, -17.0, 8.5),
    (13.0, -16.3, 8.1),
    (18.3, 1.8, 9.6),
    (8.8, 3.8, 9.7),
    (25.9, 3.1, 9.8),
    (17.0, 9.5, 11.0),
    (27.0, 9.0, 11.0),
    (6.3, 9.9, 10.9),
    (23.9, 16.2, 12.9),
    (15.3, 17.2, 12.9),
    (6.7, 17.3, 12.7)
]

# 计算误差：实际测量值 - 标准值 (9.1cm)
REFERENCE_Z = 9.1
calib_x = []
calib_y = []
calib_error = []
for x, y, z in CALIBRATION_DATA:
    calib_x.append(x)
    calib_y.append(y)
    calib_error.append(z - REFERENCE_Z)

# 转换为numpy数组
calib_x = np.array(calib_x)
calib_y = np.array(calib_y)
calib_error = np.array(calib_error)

# 构建二阶多项式特征矩阵： [1, x, y, x^2, y^2, x*y]
A = np.column_stack([
    np.ones_like(calib_x),
    calib_x,
    calib_y,
    calib_x**2,
    calib_y**2,
    calib_x * calib_y
])

# 使用最小二乘法拟合系数
try:
    coefficients, residuals, rank, s = np.linalg.lstsq(A, calib_error, rcond=None)
    # coefficients 顺序: [c0, c1, c2, c3, c4, c5] 对应 1, x, y, x^2, y^2, x*y
    print(f"✅ Z轴自动校正拟合完成，系数: {coefficients}")
    if len(residuals) > 0:
        print(f"   残差平方和: {residuals[0]:.4f}")
except Exception as e:
    print(f"❌ Z轴自动校正拟合失败: {e}")
    coefficients = None

def compute_z_error(x, y):
    """根据拟合的多项式计算Z轴误差"""
    if coefficients is None:
        return 0.0
    # 确保x, y是标量或数组
    x = np.asarray(x, dtype=np.float64)
    y = np.asarray(y, dtype=np.float64)
    # 计算多项式值: c0 + c1*x + c2*y + c3*x^2 + c4*y^2 + c5*x*y
    error = (coefficients[0] + 
             coefficients[1] * x + 
             coefficients[2] * y + 
             coefficients[3] * x**2 + 
             coefficients[4] * y**2 + 
             coefficients[5] * x * y)
    return error

# 测试拟合效果（可选）
if coefficients is not None:
    print("📊 拟合效果验证:")
    for i, (x, y, z) in enumerate(CALIBRATION_DATA):
        pred_error = compute_z_error(x, y)
        pred_z = z - pred_error  # 校正后的z应该接近REFERENCE_Z
        print(f"  点{i+1}: ({x:.1f}, {y:.1f}) 测量z={z:.1f}, 误差={z-REFERENCE_Z:.2f}, 预测误差={pred_error:.2f}, 校正后z={pred_z:.2f}")

